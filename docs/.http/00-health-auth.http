# rclone Manager backend: health, auth, ops links
# VS Code REST Client reads .env through {{$dotenv VAR_NAME}}.

@baseUrl = http://127.0.0.1:{{$dotenv RCLONE_MANAGER_APP_HOST_PORT}}
@apiKey = {{$dotenv RCLONE_MANAGER_BACKEND_API_KEY}}
@firebaseIdToken = {{$dotenv RCLONE_MANAGER_HTTP_FIREBASE_ID_TOKEN}}
@sessionToken = {{$dotenv RCLONE_MANAGER_HTTP_SESSION_TOKEN}}

###
# Health does not require x-api-key.
GET {{baseUrl}}/health
Accept: application/json

###
# Firebase Auth public config for the bundled frontend.
GET {{baseUrl}}/api/auth/config
Accept: application/json

###
# Operational links derived from env hostnames.
GET {{baseUrl}}/api/ops-links
Accept: application/json
x-api-key: {{apiKey}}

###
# Exchange a Firebase ID token for an internal session token.
# Set RCLONE_MANAGER_HTTP_FIREBASE_ID_TOKEN in .env when you want to run this.
POST {{baseUrl}}/api/auth/google
Accept: application/json
Content-Type: application/json

{
  "idToken": "{{firebaseIdToken}}"
}

###
# Check an internal auth session.
# Set RCLONE_MANAGER_HTTP_SESSION_TOKEN in .env, or paste the token returned above.
GET {{baseUrl}}/api/auth/me
Accept: application/json
Authorization: Bearer {{sessionToken}}
